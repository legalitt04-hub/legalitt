    alignItems: 'center',
  },
  bookNowText: { fontSize: 11, fontWeight: '600', color: '#FFFFFF' },
  loadMoreButton: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'center',
    marginHorizontal: 20,
    marginTop: 16,
    paddingVertical: 14,
    backgroundColor: '#F0FDFA',
