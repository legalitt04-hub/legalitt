// screens/client/SearchScreen.jsx - WITH PAGINATION
import React, { useState, useEffect } from 'react';
import {
  View,
  Text,
  StyleSheet,
  ScrollView,
  TextInput,
  TouchableOpacity,
  Image,
  SafeAreaView,
  StatusBar,
  ActivityIndicator,
  RefreshControl,
} from 'react-native';
import { Ionicons } from '@expo/vector-icons';
import { LinearGradient } from 'expo-linear-gradient';
import { COLORS } from '../../constants/theme';
import { advocateAPI } from '../../services/api';

const SearchScreen = ({ navigation }) => {
  const [searchQuery, setSearchQuery] = useState('');
  const [advocates, setAdvocates] = useState([]);
  const [filteredAdvocates, setFilteredAdvocates] = useState([]);
  const [loading, setLoading] = useState(true);
  const [loadingMore, setLoadingMore] = useState(false);
  const [refreshing, setRefreshing] = useState(false);
  const [page, setPage] = useState(1);
  const [hasMore, setHasMore] = useState(true);
  
  const ITEMS_PER_PAGE = 50;

  useEffect(() => {
    fetchAdvocates(1, true);
  }, []);

  useEffect(() => {
    // Filter advocates when search query changes
    if (searchQuery.trim()) {
      const filtered = advocates.filter((adv) =>
        adv.name?.toLowerCase().includes(searchQuery.toLowerCase()) ||
        adv.specializations?.some(spec => 
          spec.toLowerCase().includes(searchQuery.toLowerCase())
        )
      );
      setFilteredAdvocates(filtered);
    } else {
      setFilteredAdvocates(advocates);
    }
  }, [searchQuery, advocates]);

  const fetchAdvocates = async (pageNum = 1, reset = false) => {
    try {
      if (reset) {
        setLoading(true);
        setAdvocates([]);
      } else {
        setLoadingMore(true);
      }

      const response = await advocateAPI.getAdvocates({
        limit: ITEMS_PER_PAGE,
        page: pageNum,
      });

      if (response.data.success) {
        const newAdvocates = response.data.data || [];
        
        if (reset) {
          setAdvocates(newAdvocates);
        } else {
          setAdvocates(prev => [...prev, ...newAdvocates]);
        }

        // Check if there are more advocates to load
        setHasMore(newAdvocates.length === ITEMS_PER_PAGE);
        setPage(pageNum);
      }
    } catch (error) {
      console.error('Error fetching advocates:', error);
    } finally {
      setLoading(false);
      setLoadingMore(false);
      setRefreshing(false);
    }
  };

  const onRefresh = () => {
    setRefreshing(true);
    setPage(1);
    fetchAdvocates(1, true);
  };

  const loadMore = () => {
    if (!loadingMore && hasMore) {
      fetchAdvocates(page + 1, false);
    }
  };

  return (
    <SafeAreaView style={styles.container}>
      <StatusBar barStyle="dark-content" backgroundColor="#FFFFFF" />

      {/* Header */}
      <View style={styles.header}>
        <TouchableOpacity style={styles.backButton} onPress={() => navigation.goBack()}>
          <Ionicons name="chevron-back" size={24} color="#1F2937" />
        </TouchableOpacity>
        <Text style={styles.headerTitle}>Find Advocates</Text>
        <View style={{ width: 24 }} />
      </View>

      {/* Search Bar with Filter */}
      <View style={styles.searchContainer}>
        <View style={styles.searchInputWrapper}>
          <Ionicons name="search-outline" size={16} color="#9CA3AF" style={styles.searchIcon} />
          <TextInput
            style={styles.searchInput}
            placeholder="Search by name or specialization..."
            placeholderTextColor="#9CA3AF"
            value={searchQuery}
            onChangeText={setSearchQuery}
          />
          {searchQuery.length > 0 && (
            <TouchableOpacity onPress={() => setSearchQuery('')}>
              <Ionicons name="close-circle" size={18} color="#9CA3AF" />
            </TouchableOpacity>
          )}
        </View>
        <TouchableOpacity
          style={styles.filterButton}
          onPress={() => navigation.navigate('Filter')}
        >
          <Ionicons name="options-outline" size={18} color={COLORS.primary} />
        </TouchableOpacity>
      </View>

      <ScrollView
        style={styles.scrollView}
        contentContainerStyle={styles.scrollContent}
        showsVerticalScrollIndicator={false}
        refreshControl={
          <RefreshControl refreshing={refreshing} onRefresh={onRefresh} />
        }
      >
        {/* Map Preview */}
        <TouchableOpacity
          style={styles.mapPreview}
          onPress={() => navigation.navigate('Map')}
          activeOpacity={0.9}
        >
          <LinearGradient
            colors={['#E0F2FE', '#BAE6FD', '#7DD3FC']}
            start={{ x: 0, y: 0 }}
            end={{ x: 1, y: 1 }}
            style={styles.mapGradient}
          >
            <View style={styles.viewMapButton}>
              <Ionicons name="map-outline" size={16} color="#1F2937" style={{ marginRight: 6 }} />
              <Text style={styles.viewMapText}>View on Map</Text>
            </View>
          </LinearGradient>
        </TouchableOpacity>

        {/* Loading Initial */}
        {loading ? (
          <View style={styles.loadingContainer}>
            <ActivityIndicator size="large" color={COLORS.primary} />
            <Text style={styles.loadingText}>Loading advocates...</Text>
          </View>
        ) : (
          <>
            {/* Results Count */}
            <View style={styles.resultsHeader}>
              <Text style={styles.resultsCount}>
                {filteredAdvocates.length} advocate{filteredAdvocates.length !== 1 ? 's' : ''} found
              </Text>
              {searchQuery.length > 0 && (
                <Text style={styles.searchingText}>Searching for "{searchQuery}"</Text>
              )}
            </View>

            {/* Advocates List */}
            {filteredAdvocates.length === 0 ? (
              <View style={styles.emptyContainer}>
                <Ionicons name="search-outline" size={48} color="#D1D5DB" />
                <Text style={styles.emptyText}>No advocates found</Text>
                <Text style={styles.emptySubtext}>Try adjusting your search or filters</Text>
              </View>
            ) : (
              <View style={styles.advocatesList}>
                {filteredAdvocates.map((advocate, index) => (
                  <AdvocateCard
                    key={`adv-${index}`}
                    advocate={advocate}
                    onPress={() => navigation.navigate('AdvocateProfile', { id: advocate._id })}
                    onBook={() => navigation.navigate('Payment', { advocateId: advocate._id })}
                  />
                ))}
              </View>
            )}

            {/* Load More Button */}
            {!searchQuery && hasMore && !loading && (
              <TouchableOpacity
                style={styles.loadMoreButton}
                onPress={loadMore}
                disabled={loadingMore}
              >
                {loadingMore ? (
                  <ActivityIndicator size="small" color={COLORS.primary} />
                ) : (
                  <>
                    <Text style={styles.loadMoreText}>Load More Advocates</Text>
                    <Ionicons name="chevron-down" size={20} color={COLORS.primary} />
                  </>
                )}
              </TouchableOpacity>
            )}

            {/* End of Results */}
            {!hasMore && advocates.length > 0 && (
              <Text style={styles.endText}>You've reached the end</Text>
            )}
          </>
        )}

        <View style={{ height: 100 }} />
      </ScrollView>
    </SafeAreaView>
  );
};

// Advocate Card Component
const AdvocateCard = ({ advocate, onPress, onBook }) => (
  <TouchableOpacity style={styles.advocateCard} onPress={onPress} activeOpacity={0.7}>
    <Image
      source={{ 
        uri: advocate.user?.avatar || advocate.profilePicture || 'https://i.pravatar.cc/150?img=12' 
      }}
      style={styles.advocateAvatar}
    />

    <View style={styles.advocateInfo}>
      <View style={styles.advocateNameRow}>
        <Text style={styles.advocateName} numberOfLines={1}>
          {advocate.name || advocate.user?.name || 'Advocate'}
        </Text>
        {advocate.isVerified && (
          <View style={styles.verifiedBadge}>
            <Ionicons name="checkmark" size={8} color="#FFFFFF" />
          </View>
        )}
      </View>

      <Text style={styles.advocateTitle} numberOfLines={1}>
        {advocate.specializations?.[0] || 'Legal Advisor'}
      </Text>
      <Text style={styles.advocateTags} numberOfLines={1}>
        {advocate.city || 'India'} • {advocate.experience || 5}+ years
      </Text>

      <View style={styles.ratingRow}>
        <Ionicons name="star" size={10} color="#FCD34D" />
        <Text style={styles.ratingText}>{advocate.rating?.average || advocate.rating || 4.5}</Text>
        <Text style={styles.reviewsText}>({advocate.rating?.count || advocate.reviewCount || 0})</Text>
      </View>

      <Text style={styles.feeText}>
        <Text style={styles.feeBold}>₹{advocate.consultationFee || 2000}/</Text> Consultation
      </Text>
    </View>

    <View style={styles.advocateActions}>
      <TouchableOpacity style={styles.viewProfileButton} onPress={onPress}>
        <Text style={styles.viewProfileText}>View</Text>
      </TouchableOpacity>

      <TouchableOpacity style={styles.bookNowButton} onPress={onBook}>
        <Text style={styles.bookNowText}>Book</Text>
      </TouchableOpacity>
    </View>
  </TouchableOpacity>
);

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#FFFFFF' },
  header: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingHorizontal: 16,
    paddingVertical: 16,
    borderBottomWidth: 1,
    borderBottomColor: '#E5E7EB',
  },
  backButton: { padding: 4 },
  headerTitle: { fontSize: 18, fontWeight: '600', color: '#1F2937' },
  searchContainer: {
    flexDirection: 'row',
    paddingHorizontal: 20,
    paddingVertical: 12,
    gap: 8,
    backgroundColor: '#FFFFFF',
    borderBottomWidth: 1,
    borderBottomColor: '#F3F4F6',
  },
  searchInputWrapper: {
    flex: 1,
    flexDirection: 'row',
    alignItems: 'center',
    backgroundColor: '#F9FAFB',
    borderRadius: 28,
    paddingHorizontal: 16,
    height: 44,
    borderWidth: 1,
    borderColor: '#E5E7EB',
  },
  searchIcon: { marginRight: 8 },
  searchInput: { flex: 1, fontSize: 14, color: '#1F2937' },
  filterButton: {
    width: 44,
    height: 44,
    borderRadius: 22,
    backgroundColor: '#F0FDFA',
    borderWidth: 1,
    borderColor: COLORS.primary,
    alignItems: 'center',
    justifyContent: 'center',
  },
  scrollView: { flex: 1 },
  scrollContent: { paddingBottom: 20 },
  mapPreview: {
    marginHorizontal: 20,
    marginTop: 16,
    height: 100,
    borderRadius: 16,
    overflow: 'hidden',
    marginBottom: 16,
    shadowColor: '#000',
    shadowOffset: { width: 0, height: 2 },
    shadowOpacity: 0.1,
    shadowRadius: 4,
    elevation: 3,
  },
  mapGradient: { flex: 1, justifyContent: 'center', alignItems: 'center' },
  viewMapButton: {
    flexDirection: 'row',
    alignItems: 'center',
    backgroundColor: '#FFFFFF',
    paddingHorizontal: 16,
    paddingVertical: 8,
    borderRadius: 20,
    shadowColor: '#000',
    shadowOffset: { width: 0, height: 2 },
    shadowOpacity: 0.15,
    shadowRadius: 4,
    elevation: 4,
  },
  viewMapText: { fontSize: 13, fontWeight: '600', color: '#1F2937' },
  loadingContainer: { paddingVertical: 60, alignItems: 'center' },
  loadingText: { marginTop: 12, fontSize: 14, color: '#6B7280' },
  resultsHeader: { paddingHorizontal: 20, marginBottom: 12 },
  resultsCount: { fontSize: 16, fontWeight: '600', color: '#1F2937', marginBottom: 4 },
  searchingText: { fontSize: 12, color: '#6B7280' },
  emptyContainer: { paddingVertical: 60, alignItems: 'center' },
  emptyText: { fontSize: 16, fontWeight: '600', color: '#6B7280', marginTop: 12 },
  emptySubtext: { fontSize: 13, color: '#9CA3AF', marginTop: 4 },
  advocatesList: { paddingHorizontal: 20, gap: 12 },
  advocateCard: {
    flexDirection: 'row',
    backgroundColor: '#F9FAFB',
    borderRadius: 16,
    padding: 12,
    gap: 12,
    marginBottom: 8,
  },
  advocateAvatar: { width: 64, height: 64, borderRadius: 16 },
  advocateInfo: { flex: 1 },
  advocateNameRow: { flexDirection: 'row', alignItems: 'center', gap: 4, marginBottom: 2 },
  advocateName: { fontSize: 15, fontWeight: '600', color: '#1F2937', flex: 1 },
  verifiedBadge: {
    width: 16,
    height: 16,
    borderRadius: 8,
    backgroundColor: COLORS.primary,
    alignItems: 'center',
    justifyContent: 'center',
  },
  advocateTitle: { fontSize: 12, color: '#6B7280', marginBottom: 2 },
  advocateTags: { fontSize: 11, color: '#9CA3AF', marginBottom: 4 },
  ratingRow: { flexDirection: 'row', alignItems: 'center', gap: 4, marginBottom: 4 },
  ratingText: { fontSize: 12, fontWeight: '600', color: '#1F2937' },
  reviewsText: { fontSize: 11, color: '#6B7280' },
  feeText: { fontSize: 12, color: '#6B7280' },
  feeBold: { fontWeight: '600', color: COLORS.primary },
  advocateActions: { gap: 6, justifyContent: 'center' },
  viewProfileButton: {
    borderWidth: 1,
    borderColor: COLORS.primary,
    paddingHorizontal: 14,
    paddingVertical: 6,
    borderRadius: 12,
    alignItems: 'center',
  },
  viewProfileText: { fontSize: 11, fontWeight: '600', color: COLORS.primary },
  bookNowButton: {
    backgroundColor: COLORS.primary,
    paddingHorizontal: 14,
    paddingVertical: 6,
