    borderWidth: 1,
    borderColor: COLORS.primary,
    gap: 6,
  },
  loadMoreText: { fontSize: 14, fontWeight: '600', color: COLORS.primary },
  endText: {
    textAlign: 'center',
    marginTop: 20,
    fontSize: 13,
    color: '#9CA3AF',
  },
});

export default SearchScreen;
