    <Path d="M36 127H83C87.4183 127 91 130.582 91 135V138H28V135C28 130.582 31.5817 127 36 127Z" stroke="white" strokeWidth="4" />
    <Path d="M47 114H72C76.4183 114 80 117.582 80 122V125H39V122C39 117.582 42.5817 114 47 114Z" stroke="white" strokeWidth="4" />
  </Svg>
);

const GavelStrike = () => (
  <Svg width="149" height="134" viewBox="0 0 149 134" fill="none">
    <Path
      fillRule="evenodd"
      clipRule="evenodd"
      d="M74.7549 67.7534L59.0849 77.9412C58.1846 78.5272 57.1775 78.9301 56.1213 79.1267C55.0652 79.3234 53.9806 79.3099 52.9296 79.0871C51.8787 78.8642 50.8819 78.4364 49.9964 77.8282C49.1109 77.2199 48.3539 76.443 47.7689 75.542L39.3526 62.5968C38.1716 60.7793 37.7606 58.5672 38.2102 56.4468C38.6597 54.3265 39.9329 52.4714 41.7499 51.2895L61.5501 38.4166C61.0502 38.754 60.4882 38.9885 59.8968 39.1065C59.3054 39.2244 58.6964 39.2234 58.1054 39.1034C57.5144 38.9835 56.9532 38.747 56.4545 38.4078C55.9559 38.0687 55.5298 37.6336 55.201 37.128C54.8723 36.6224 54.6476 36.0564 54.54 35.463C54.4323 34.8697 54.444 34.2608 54.5742 33.6719C54.7044 33.0831 54.9505 32.5261 55.2983 32.0334C55.6461 31.5407 56.0885 31.1222 56.5997 30.8024L64.2139 25.852C65.223 25.2196 66.4401 25.0089 67.6031 25.2651C68.766 25.5214 69.7818 26.2242 70.4316 27.2222C71.0814 28.2201 71.3133 29.4334 71.0773 30.6006C70.8412 31.7678 70.1562 32.7957 69.1696 33.4627L88.9689 20.5942C90.7864 19.4132 92.9985 19.0022 95.1188 19.4518C97.2392 19.9013 99.0942 21.1745 100.276 22.9915L108.692 35.9367C109.278 36.8369 109.68 37.8435 109.876 38.8992C110.073 39.9549 110.059 41.0389 109.837 42.0893C109.614 43.1398 109.186 44.136 108.579 45.0212C107.971 45.9064 107.194 46.6632 106.294 47.2484L90.6241 57.4361L122.123 98.2795L122.335 98.5749C123.18 99.875 123.761 101.329 124.044 102.853C124.328 104.378 124.308 105.944 123.986 107.461C123.665 108.978 123.047 110.416 122.17 111.695C121.292 112.973 120.171 114.066 118.871 114.912L115.823 116.893C114.497 117.754 113.012 118.339 111.455 118.615C109.898 118.891 108.302 118.851 106.761 118.498C105.22 118.146 103.765 117.487 102.483 116.562C101.202 115.636 100.119 114.463 99.2988 113.111L74.7549 67.7534ZM82.3916 62.7846L82.984 62.3995L114.792 103.647C115.141 104.252 115.245 104.968 115.082 105.647C114.919 106.326 114.502 106.916 113.916 107.296L110.873 109.279C110.286 109.66 109.576 109.8 108.888 109.672C108.201 109.544 107.589 109.156 107.18 108.589L82.3916 62.7846Z"
      fill="white"
    />
    <Path d="M10 121H57C61.4183 121 65 124.582 65 129V132H2V129C2 124.582 5.58172 121 10 121Z" stroke="white" strokeWidth="4" />
    <Path d="M21 108H46C50.4183 108 54 111.582 54 116V119H13V116C13 111.582 16.5817 108 21 108Z" stroke="white" strokeWidth="4" />
  </Svg>
);

const ImpactRing = ({ size, delay, opacity: opacityLevel }) => {
  const opacity = useRef(new Animated.Value(0)).current;
  const scale = useRef(new Animated.Value(0.3)).current;

  useEffect(() => {
    Animated.sequence([
      Animated.delay(delay),
      Animated.parallel([
        Animated.timing(opacity, { toValue: opacityLevel, duration: 150, useNativeDriver: true }),
        Animated.spring(scale, { toValue: 1, friction: 6, tension: 40, useNativeDriver: true }),
      ]),
      Animated.timing(opacity, { toValue: 0, duration: 400, useNativeDriver: true }),
    ]).start();
  }, []);

  return (
    <Animated.View
      style={{
        position: 'absolute',
        width: size,
        height: size,
        borderRadius: size / 2,
        borderWidth: 3,
        borderColor: 'rgba(255, 255, 255, 0.6)',
        opacity,
        transform: [{ scale }],
      }}
    />
  );
};

export default function SplashScreen({ navigation }) {
  const staticOpacity = useRef(new Animated.Value(0)).current;
  const staticScale = useRef(new Animated.Value(0.5)).current;
  const strikeOpacity = useRef(new Animated.Value(0)).current;
  const strikeScale = useRef(new Animated.Value(0.85)).current;
  const strikeRotate = useRef(new Animated.Value(0)).current;
  const screenOpacity = useRef(new Animated.Value(1)).current;
  const [showRings, setShowRings] = useState(false);

  useEffect(() => {
    StatusBar.setBackgroundColor(TEAL);
    StatusBar.setBarStyle('light-content');

    Animated.sequence([
      // 1. STATIC GAVEL appears (smooth fade + scale)
      Animated.parallel([
        Animated.timing(staticOpacity, { 
          toValue: 1, 
          duration: 600, 
          useNativeDriver: true 
        }),
        Animated.spring(staticScale, { 
          toValue: 1, 
          friction: 6, 
          tension: 60, 
          useNativeDriver: true 
        }),
      ]),
      
      // Hold static gavel for a moment
      Animated.delay(400),

      // 2. SWAP TO STRIKE GAVEL (quick transition)
      Animated.parallel([
        Animated.timing(staticOpacity, { 
          toValue: 0, 
          duration: 100, 
          useNativeDriver: true 
        }),
        Animated.timing(strikeOpacity, { 
          toValue: 1, 
          duration: 150, 
          useNativeDriver: true 
        }),
        Animated.spring(strikeScale, { 
          toValue: 1, 
          friction: 5, 
          tension: 100, 
          useNativeDriver: true 
        }),
        Animated.timing(strikeRotate, {
          toValue: 1,
          duration: 150,
          useNativeDriver: true
        }),
      ]),

      // Hold strike pose with rings
      Animated.delay(800),

      // 3. FADE OUT entire screen
      Animated.timing(screenOpacity, { 
        toValue: 0, 
        duration: 500, 
        useNativeDriver: true 
      }),
    ]).start(() => {
      navigation?.replace('Logo');
    });

    // Show impact rings when gavel strikes
    setTimeout(() => setShowRings(true), 1100);
  }, []);

  const strikeRotateInterpolate = strikeRotate.interpolate({
    inputRange: [0, 1],
    outputRange: ['0deg', '-5deg'],
  });

  return (
    <Animated.View style={[styles.container, { opacity: screenOpacity }]}>
      <StatusBar backgroundColor={TEAL} barStyle="light-content" />

      {/* Impact rings appear on strike */}
      {showRings && (
        <>
          <ImpactRing size={280} delay={0} opacityLevel={0.2} />
          <ImpactRing size={220} delay={80} opacityLevel={0.3} />
          <ImpactRing size={160} delay={160} opacityLevel={0.5} />
        </>
      )}

      {/* STATIC GAVEL (shows first) */}
      <Animated.View
        style={[
          styles.center,
          {
            opacity: staticOpacity,
            transform: [{ scale: staticScale }],
          },
        ]}
      >
        <GavelStatic />
      </Animated.View>

      {/* STRIKE GAVEL (shows second) */}
      <Animated.View
        style={[
          styles.center,
          {
            opacity: strikeOpacity,
            transform: [
              { scale: strikeScale },
              { rotate: strikeRotateInterpolate },
            ],
          },
        ]}
      >
        <GavelStrike />
      </Animated.View>
    </Animated.View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    backgroundColor: TEAL,
    alignItems: 'center',
    justifyContent: 'center',
  },
  center: {
    position: 'absolute',
    alignItems: 'center',
    justifyContent: 'center',
  },
});
